# Ports
HOST_PORT=5173
WORKBENCH_PORT=5174
ENVOY_PORT=8080
GRPC_PORT=9090

# App database
APP_DB_HOST=postgres-app
APP_DB_PORT=5432
APP_DB_HOST_PORT=5433
APP_DB_NAME=sqlclient_app
APP_DB_USER=sqlclient
APP_DB_PASSWORD=change_me
APP_DB_DSN=postgres://sqlclient:change_me@postgres-app:5432/sqlclient_app?sslmode=disable

# Sandbox database
SANDBOX_DB_HOST=postgres-sandbox
SANDBOX_DB_PORT=5432
SANDBOX_DB_HOST_PORT=5434
SANDBOX_DB_NAME=sqlclient_sandbox
SANDBOX_DB_USER=sandbox_user
SANDBOX_DB_PASSWORD=change_me
SANDBOX_DB_DSN=postgres://sandbox_user:change_me@postgres-sandbox:5432/sqlclient_sandbox?sslmode=disable

# SQL execution limits
QUERY_TIMEOUT_MS=5000
MAX_ROWS=500

# Frontend
VITE_APP_API_URL=http://localhost:8080
VITE_APP_GRPC_WEB_BASE_URL=http://localhost:8080
VITE_APP_TITLE=SQL Client
